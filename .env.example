# ================================================
# SIBE - Variables de Entorno
# Copiar este archivo como .env y ajustar los valores.
# ================================================

# --- Base de Datos (PostgreSQL) ---
POSTGRES_DB=sibe_db2
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_PORT=5432

# --- Backend (Spring Boot) ---
BACKEND_PORT=8080
DDL_AUTO=update
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost
JWT_SECRET=changeme-generate-a-256-bit-key
ADMIN_DEFAULT_PASSWORD=changeme
APP_NAME=SIBE

# --- Frontend (Nginx) ---
FRONTEND_PORT=80

# --- Email (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=changeme@gmail.com
MAIL_PASSWORD=changeme

# --- Limites de subida de archivos ---
UPLOAD_MAX_FILE_SIZE=50MB
UPLOAD_MAX_REQUEST_SIZE=50MB
